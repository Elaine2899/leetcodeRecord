# Definition for a binary tree node.
# class TreeNode(object):
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution(object):
    def maxDepth(self, root):
        """
        :type root: Optional[TreeNode]
        :rtype: int
        """
        ans = 0
        def countDepth(r, level):
            if not r:
                return level
            else:
                level = max(countDepth(r.left, level),countDepth(r.right, level))
                return level+1
        ans = countDepth(root, ans)
        return ans

        
