class Solution(object):
    def longestCommonPrefix(self, strs):
        """
        :type strs: List[str]
        :rtype: str
        """
        result = ""
        prefix = ""
        isAdd = True

        for i in range(len(strs[0])):
            nowPre = strs[0][i] 
            for j in range(1, len(strs)):
                if len(strs[j]) > i:
                    if strs[j][i] != nowPre:
                        isAdd = False
                        break
                    else:
                        isAdd = True
                else:
                    isAdd = False
                    break
            if isAdd == False:
                break
            else:
                prefix += strs[0][i]
            
        return prefix
                