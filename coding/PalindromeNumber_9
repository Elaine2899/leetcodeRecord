class Solution {
public:
    bool isPalindrome(int x) {
        if(x < 0){
            return false;
        }else{
            long long tem = 0;
            int tar = x;
            while(tar > 0){
                tem = tem*10 + tar%10;
                tar /= 10;
            }
            return(tem == x);
        }
    }
};