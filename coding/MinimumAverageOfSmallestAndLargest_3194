class Solution(object):
    def minimumAverage(self, nums):
        """
        :type nums: List[int]
        :rtype: float
        """
        minAvg = float('inf')
        nums.sort()
        size = len(nums)
        left = 0
        right = size - 1
        while left < right:
            minAvg = min(minAvg, ((nums[left] + nums[right]) / 2.0))
            left += 1
            right -= 1
        return minAvg
