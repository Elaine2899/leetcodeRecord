"""
# Definition for a Node.
class Node:
    def __init__(self, val: Optional[int] = None, children: Optional[List['Node']] = None):
        self.val = val
        self.children = children
"""

class Solution:
    def postorder(self, root: 'Node') -> List[int]:
        ans = []
        def rep(node): 
            if not node:
                return
            for ch in node.children:
                rep(ch)
            ans.append(node.val)
        rep(root)
        return ans
