class Solution:
    def minBitwiseArray(self, nums: List[int]) -> List[int]:
        ans = [0] * len(nums)
        for i, x in enumerate(nums):
            for k in range(x):
                if k | (k+1) == x:
                    ans[i] = k
                    break
                if k == x-1:
                    ans[i] = -1
        return ans
