class Solution(object):
    def findMissingAndRepeatedValues(self, grid):
        """
        :type grid: List[List[int]]
        :rtype: List[int]
        """
        n = len(grid)
        end = n*n
        stack = []
        ans = []
        for i in range(0, n):
            for j in grid[i]:
                if j in stack:
                    ans.append(j)
                else:
                    stack.append(j)
        for i in range(1, end+1):
            if i not in stack:
                ans.append(i)
        return ans
