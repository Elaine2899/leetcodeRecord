class Solution(object):
    def mySqrt(self, x):
        """
        :type x: int
        :rtype: int
        """
        r = x
        l = 0
        while l <= r:
            m = (r+l) // 2
            if m*m == x:
                return m
            elif m*m < x:
                l = m+1
            else:
                r = m-1
                
        return r